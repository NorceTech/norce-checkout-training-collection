      "elements": [
        {
          "type": "header"
        },
        {
          "type": "confirmation"
        }
      ],
      "active": true
    },
    {
      "$schema": "https://checkout-configuration.test.norce.tech/openapi/v1/schemas/configuration.json",
      "id": "checkout_layout_order",
      "type": "container",
      "elements": [
        {
          "type": "header"
        },
        {
          "id": "grid",
          "type": "container",
          "elements": [
            {
              "id": "grid-column-1",
              "type": "container",
              "elements": [
                {
                  "type": "cart"
                },
                {
                  "type": "summary"
                },
                {
                  "type": "discount"
