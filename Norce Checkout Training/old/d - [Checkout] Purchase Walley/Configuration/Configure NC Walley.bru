    {
      "$schema": "https://{{slug}}.api-se.playground.norce.tech/checkout/walley-adapter/openapi/v1/schemas/walley_checkout_adapter.json",
      "id": "walley_checkout_adapter",
      "apiSettings": {
        "clientId": "7eba8c54-ea5e-4400-8b49-94b64f5485e9",
        "apiUrl": "https://api.uat.walleydev.com",
        "authenticationUrl": "https://api.uat.walleydev.com",
        "frontEndUrl": "https://checkout.uat.walleydev.com",
        "scope": "705798e0-8cef-427c-ae00-6023deba29af/.default",
        "apiSecret": "lfN8Q~HoBVTInjgQPzq60TsV6-loKqBFBq8Lvcws",
        "useDeliveryModule": true,
        "storeId-SE-B2C": "5538",
        "storeId-SE-B2B": "5539"
      },
      "redirectUrls": {
        "merchantTermsUri": "https://norce.io/terms?merchant={merchant}&channel={channel}",
        "redirectPageUri": "https://norce.io/newcheckout?orderId={orderId}&merchant={merchant}&channel={channel}",
        "validationUri": "https://{{slug}}.api-se.playground.norce.tech/checkout/walley-adapter",
        "checkoutAbortedRedirectPageUri": "https://norce.io?orderId={orderId}&merchant={merchant}&channel={channel}",
        "notificationUri": "https://checkout-walley-adapter.test.norce.tech"
      },
      "options": {
