meta {
  name: Configure NC Walley
  type: http
  seq: 1
}

put {
  url: {{configurationUrl}}/api/v1/configuration/merchants/{{merchant}}/channels/{{channel}}/configurations
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  [
    {
      "$schema": "https://{{slug}}.checkoutadmin-se.playground.norce.tech/api/schemas/v1/admin_meta_schema.json?v=1",
      "id": "admin_meta",
      "configs": [
              {
          "schema": "https://{{slug}}.api-se.playground.norce.tech/checkout/norce-adapter/openapi/v1/schemas/norce_adapter.json",
          "id": "norce_adapter",
          "imgUrl": "https://media.test.cdn-norce.tech/1000/728e73aa-aebd-4a33-ae00-e961366d109a",
          "tags": [
            "Platform"
          ]
        },
        {
          "schema": "https://{{slug}}.api-se.playground.norce.tech/checkout/walley-adapter/openapi/v1/schemas/walley_checkout_adapter.json",
          "id": "walley_checkout_adapter",
          "imgUrl": "https://media.test.cdn-norce.tech/1000/a16d716f-3a79-4d13-b89b-41c8e46c3a35",
