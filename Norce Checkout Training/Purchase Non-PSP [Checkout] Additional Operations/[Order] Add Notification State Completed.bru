meta {
  name: [Order] Add Notification State Completed
  type: http
  seq: 12
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/notifications
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "description": "Mail notification",
    "scope": "/state/currentStatus",
    "schema": {
      "enum": [
        "completed"
      ]
    },
    "invoke": "https://webhook.site/4e8b9398-ba1b-4dcf-b96a-4ec18057e46d/{order_id}"
  }
}
