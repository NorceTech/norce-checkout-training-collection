meta {
  name: [Non-PSP Adapter] Select Payment Method
  type: http
  seq: 4
}

put {
  url: {{nonpspAdapterUrl}}/api/checkout/v1/orders/{{orderId}}/payments/{{paymentId}}
  body: json
  auth: inherit
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

body:json {
  {
    "selectedPaymentMethod": "account-credit"
  }
}
