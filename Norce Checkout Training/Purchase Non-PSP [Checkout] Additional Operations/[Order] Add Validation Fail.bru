meta {
  name: [Order] Add Validation Fail
  type: http
  seq: 14
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/validations
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "invoke": "https://400.returnco.de/whatever",
    "adapterId": "onhand_verify"
  }
}
