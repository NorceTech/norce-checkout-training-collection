meta {
  name: [Norce Adapter] Order (Sync Commerce)
  type: http
  seq: 6
}

put {
  url: {{norceAdapterUrl}}/api/v1/orders/{{orderId}}
  body: none
  auth: inherit
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

docs {
  Use this endpoint to sync changes made on the basket in commerce and update the checkout order to match.
}
