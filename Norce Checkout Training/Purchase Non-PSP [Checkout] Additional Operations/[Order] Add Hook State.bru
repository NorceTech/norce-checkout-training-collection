meta {
  name: [Order] Add Hook State
  type: http
  seq: 13
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/hooks
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "version": "v0",
    "scope": "/state",
    "invoke": "https://webhook.site/4e8b9398-ba1b-4dcf-b96a-4ec18057e46d",
    "adapterId": "external_reserve"
  }
}
