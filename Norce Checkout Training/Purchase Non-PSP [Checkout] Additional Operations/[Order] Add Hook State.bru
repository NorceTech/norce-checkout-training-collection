meta {
  name: [Order] Add Hook State
  type: http
  seq: 14
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/hooks
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "version": "v0",
    "scope": "/state",
    "invoke": "https://webhook.site/aabc10ea-51ab-46c0-b4bc-a654cf260d99",
    "adapterId": "external_reserve"
  }
}
