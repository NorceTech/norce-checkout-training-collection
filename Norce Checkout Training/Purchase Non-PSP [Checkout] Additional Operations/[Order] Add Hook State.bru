meta {
  name: [Order] Add Hook State
  type: http
  seq: 15
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/hooks
  body: json
  auth: inherit
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

body:json {
  {
    "version": "v0",
    "scope": "/state",
    "invoke": "{{webhooksiteurl}}",
    "adapterId": "external_reserve"
  }
}
