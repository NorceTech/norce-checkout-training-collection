meta {
  name: [Order] Add Validation External Onhand
  type: http
  seq: 13
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/validations
  body: json
  auth: inherit
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

body:json {
  {
    "invoke": "{{webhooksiteurl}}/validate",
    "adapterId": "onhand_verify"
  }
}
