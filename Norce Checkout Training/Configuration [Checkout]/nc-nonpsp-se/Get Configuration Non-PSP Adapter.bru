meta {
  name: Get Configuration Non-PSP Adapter
  type: http
  seq: 5
}

get {
  url: {{configurationUrl}}/api/v1/configuration/merchants/{{merchant}}/channels/{{channel}}/configurations/nonpsp_adapter
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}


