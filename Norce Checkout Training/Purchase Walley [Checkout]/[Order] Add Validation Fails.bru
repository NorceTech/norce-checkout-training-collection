meta {
  name: [Order] Add Validation Fails
  type: http
  seq: 4
}

post {
  url: {{orderUrl}}/api/v1/checkout/orders/{{orderId}}/validations
  body: json
  auth: bearer
}

headers {
  x-merchant: {{merchant}}
  x-channel: {{channel}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "invoke": "https://httpstat.us/400",
    "adapterId": "fail_verify"
  }
}
