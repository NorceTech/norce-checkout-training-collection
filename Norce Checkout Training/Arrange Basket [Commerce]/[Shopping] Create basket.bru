meta {
  name: [Shopping] Create basket
  type: http
  seq: 1
}

post {
  url: {{commerceShoppingServiceUrl}}/CreateBasket?ipAddress=127.0.0.1&createdBy=1&format=json
  body: json
  auth: inherit
}

params:query {
  ipAddress: 127.0.0.1
  createdBy: 1
  format: json
}

headers {
  Content-Type: application/json
  applicationId: {{commerceApplicationId}}
}

body:json {
  {}
}

vars:post-response {
  basketId: res.body.Id
}

assert {
  res.status: eq 200
  res('Id'): isDefined
}
